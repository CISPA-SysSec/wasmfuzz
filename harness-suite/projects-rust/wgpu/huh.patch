diff --git a/naga/fuzz/fuzz_targets/ir.rs b/naga/fuzz/fuzz_targets/ir.rs
index f2e7bea3f..a766d7228 100644
--- a/naga/fuzz/fuzz_targets/ir.rs
+++ b/naga/fuzz/fuzz_targets/ir.rs
@@ -4,12 +4,13 @@
 mod fuzz {
     use libfuzzer_sys::fuzz_target;
 
-    fuzz_target!(|module: naga::Module| {
+    fuzz_target!(|data: &[u8]| {
         use naga::valid as v;
-        // Check if the module validates without errors.
-        //TODO: may also fuzz the flags and capabilities
-        let mut validator =
-            v::Validator::new(v::ValidationFlags::all(), v::Capabilities::default());
+
+        let module = naga::Module::default();
+        let flags = v::ValidationFlags::from_bits_truncate(data.first().copied().unwrap_or(0));
+        let caps = v::Capabilities::from_bits_truncate(u64::from(data.get(1).copied().unwrap_or(0)));
+        let mut validator = v::Validator::new(flags, caps);
         let _result = validator.validate(&module);
     });
 }
