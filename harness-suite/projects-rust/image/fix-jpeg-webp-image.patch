diff --git a/fuzz/fuzzers/fuzzer_script_webp.rs b/fuzz/fuzzers/fuzzer_script_webp.rs
index 4ba62ba0..7470f6f9 100644
--- a/fuzz/fuzzers/fuzzer_script_webp.rs
+++ b/fuzz/fuzzers/fuzzer_script_webp.rs
@@ -1,7 +1,19 @@
 #![no_main]
 #[macro_use] extern crate libfuzzer_sys;
 extern crate image;
+use image::ImageDecoder;
+use std::io::Cursor;
 
 fuzz_target!(|data: &[u8]| {
-    let _ = image::load_from_memory_with_format(data, image::ImageFormat::WebP);
+    let decoder = match image::codecs::webp::WebPDecoder::new(Cursor::new(data)) {
+        Ok(decoder) => decoder,
+        Err(_) => return,
+    };
+
+    if decoder.total_bytes() > 256 * 1024 * 1024 {
+        return;
+    }
+
+    let mut buf = vec![0; decoder.total_bytes() as usize];
+    let _ = decoder.read_image(&mut buf);
 });
