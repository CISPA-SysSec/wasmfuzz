     /// Read ICC profile data from the file.
     fn read_icc_profile(&mut self, icc: &ParsedIccProfile) -> ImageResult<()> {
+        // Real embedded profiles are small (typically < 4 MiB). Reject absurd sizes so
+        // adversarial headers cannot force multi-gigabyte allocations before we know
+        // the stream can supply the bytes.
+        const MAX_ICC_PROFILE_BYTES: u64 = 32 * 1024 * 1024;
+        let profile_len = u64::from(icc.profile_size);
+        if profile_len > MAX_ICC_PROFILE_BYTES {
+            return Err(DecoderError::IccProfileTooLarge(icc.profile_size).into());
+        }
+
+        let stream_len = self.reader.seek(SeekFrom::End(0))?;
+        let end = icc
+            .profile_offset
+            .checked_add(profile_len)
+            .ok_or(DecoderError::IccProfileOutOfRange)?;
+        if icc.profile_offset > stream_len || end > stream_len {
+            return Err(DecoderError::IccProfileOutOfRange.into());
+        }
+
         self.reader.seek(SeekFrom::Start(icc.profile_offset))?;
         let mut profile_data = vec![0u8; icc.profile_size as usize];
         self.reader.read_exact(&mut profile_data)?;
         self.icc_profile = Some(profile_data);
         Ok(())
     }
