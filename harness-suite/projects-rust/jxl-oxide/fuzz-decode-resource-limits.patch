+/// Maximum decompressed payload for a single auxiliary box (aligned with fuzz harness caps).
+const MAX_AUX_BOX_BYTES: usize = 128 * 1024 * 1024;
+
+/// Maximum Brotli window bits accepted for auxiliary boxes (`1 << 24` = 16 MiB ring buffer).
+///
+/// `brotli-decompressor` supports the optional large-window extension (WBITS up to 30, ~1 GiB
+/// ring buffer). JPEG XL container metadata does not require that profile; reject it so decoding
+/// stays resource-bounded.
+const MAX_BROTLI_WINDOW_BITS: u8 = 24;
+
+/// Returns the base-2 logarithm of the Brotli sliding window size implied by the first two stream
+/// bytes.
+///
+/// This mirrors [`brotli_decompressor::decode::lg_window_size`] (brotli-decompressor 5.0.0,
+/// Apache-2.0 / MIT).
+fn lg_window_size_from_prefix(first_byte: u8, second_byte: u8) -> std::result::Result<u8, ()> {
+    if first_byte & 1 == 0 {
+        return Ok(16);
+    }
+    match first_byte & 15 {
+        0x3 => return Ok(18),
+        0x5 => return Ok(19),
+        0x7 => return Ok(20),
+        0x9 => return Ok(21),
+        0xb => return Ok(22),
+        0xd => return Ok(23),
+        0xf => return Ok(24),
+        _ => match first_byte & 127 {
+            0x71 => return Ok(15),
+            0x61 => return Ok(14),
+            0x51 => return Ok(13),
+            0x41 => return Ok(12),
+            0x31 => return Ok(11),
+            0x21 => return Ok(10),
+            0x1 => return Ok(17),
+            _ => {}
+        },
+    }
+    if (first_byte & 0x80) != 0 {
+        return Err(());
+    }
+    let ret = second_byte & 0x3f;
+    if ret < 10 || ret > 30 {
+        return Err(());
+    }
+    Ok(ret)
+}
