+    /// Skip tokens until the current `{` ... `}` group is closed (caller must have consumed the
+    /// opening `{`). Used when bailing out of pathologically nested displays.
+    fn recover_skip_balanced_until_rbrace(&mut self) {
+        let mut depth = 1u32;
+        while depth > 0 {
+            match self.current_token_kind() {
+                TokenKind::EndOfFile => return,
+                TokenKind::Lbrace => {
+                    depth += 1;
+                    self.bump_any();
+                }
+                TokenKind::Rbrace => {
+                    depth -= 1;
+                    self.bump_any();
+                }
