 pub type Result<T> = std::result::Result<T, EbmlError>;
 
+/// Hard cap on EBML string/binary element payload size (hostile `data_size` on wasm32).
+const MAX_EBML_ELEMENT_BYTES: usize = 32 * 1024 * 1024;
+
+fn check_ebml_element_size(size: usize) -> Result<()> {
+    if size > MAX_EBML_ELEMENT_BYTES {
+        Err(EbmlError::ElementError("mkv: element data size exceeds limit"))
+    } else {
+        Ok(())
+    }
+}
