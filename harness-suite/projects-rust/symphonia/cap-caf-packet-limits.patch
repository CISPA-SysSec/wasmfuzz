+/// Maximum payload size for a `kuki` (magic cookie) chunk.
+const MAX_MAGIC_COOKIE_BYTES: i64 = 32 * 1024 * 1024;
+
+/// Maximum size of one CAF audio packet in variable-length modes (packet table + `next_packet`).
+pub(crate) const MAX_CAF_PACKET_PAYLOAD_BYTES: u64 = 32 * 1024 * 1024;
+
+#[inline]
+pub(crate) fn limit_caf_packet_size(size: u64) -> Result<()> {
+    if size > MAX_CAF_PACKET_PAYLOAD_BYTES {
+        decode_error("caf: packet size exceeds limit")
+    }
+    else {
+        Ok(())
+    }
