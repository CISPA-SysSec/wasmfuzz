diff --git a/tests/wasmfuzz_eh.cc b/tests/wasmfuzz_eh.cc
new file mode 100644
index 0000000..ebcf0ca
--- /dev/null
+++ b/tests/wasmfuzz_eh.cc
@@ -0,0 +1,36 @@
+#ifdef __wasi__
+
+#include <cstdio>
+#include <exception>
+
+extern "C" void wasmfuzz_exit_testcase()
+    __attribute__((__noreturn__))
+    __attribute__((__import_module__("wasmfuzz"), __import_name__("exit_testcase")));
+
+[[noreturn]] static void wasmfuzz_on_terminate() {
+  if (auto eptr = std::current_exception()) {
+    try {
+      std::rethrow_exception(eptr);
+    } catch (const std::exception& e) {
+      std::printf("exception: %s\n", e.what());
+    } catch (...) {
+      std::printf("unknown exception\n");
+    }
+  } else {
+    std::printf("terminate without active exception\n");
+  }
+  wasmfuzz_exit_testcase();
+}
+
+struct WasmfuzzEhInit {
+  WasmfuzzEhInit() { std::set_terminate(wasmfuzz_on_terminate); }
+};
+
+static WasmfuzzEhInit wasmfuzz_eh_init;
+
+extern "C" void abort(void) {
+  std::printf("abort() called\n");
+  wasmfuzz_exit_testcase();
+}
+
+#endif
