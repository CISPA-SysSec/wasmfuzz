-/* Get a bit. No bounds checking. */
+/* Fast path when caller proved coordinates land inside the bitmap. */
 static inline int
 jbig2_image_get_pixel_fast(Jbig2Image *image, int x, int y)
 {
-    const int byte = (x >> 3) + y * image->stride;
-    const int bit = 7 - (x & 7);
+    uint32_t w = image->width;
+    uint32_t h = image->height;
+    uint32_t stride = image->stride;
+    size_t nbytes;
+    size_t byte;
+    int bit;
+
+    if (x < 0 || y < 0)
+        return 0;
+    if ((uint32_t)x >= w || (uint32_t)y >= h)
+        return 0;
+
+    nbytes = (size_t)stride * (size_t)h;
+    byte = ((size_t)(uint32_t)x >> 3) + (size_t)(uint32_t)y * stride;
+    if (byte >= nbytes)
+        return 0;
 
+    bit = 7 - (x & 7);
     return ((image->data[byte] >> bit) & 1);
 }
 
