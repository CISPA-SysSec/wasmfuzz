diff --git a/libarchive/archive_read_support_filter_lz4.c b/libarchive/archive_read_support_filter_lz4.c
index acd7f515..3f91b39a 100644
--- a/libarchive/archive_read_support_filter_lz4.c
+++ b/libarchive/archive_read_support_filter_lz4.c
@@ -182,8 +182,19 @@ lz4_reader_bid(struct archive_read_filter_bidder *self,
 
 		uint32_t frame_data_size = archive_le32dec(buffer + offset_in_buffer);
 
-		// Skip over the 4 frame data size bytes, plus the value stored there.
-		offset_in_buffer += 4 + frame_data_size;
+		/*
+		 * frame_data_size is untrusted. On platforms where ssize_t is 32-bit
+		 * (e.g. wasm32), offset_in_buffer += 4 + frame_data_size can overflow
+		 * and bypass the max_lookahead checks below, leading to out-of-bounds
+		 * reads on buffer + offset_in_buffer.
+		 */
+		{
+			uint64_t off = (uint64_t)(size_t)offset_in_buffer + 4ULL
+			    + (uint64_t)frame_data_size;
+			if (off > (uint64_t)max_lookahead)
+				return (0);
+			offset_in_buffer = (ssize_t)off;
+		}
 
 		// There should be at least one more frame if this is LZ4 data.
 		if (offset_in_buffer + min_lz4_frame_size > avail) { // TODO: should this be >= ?

