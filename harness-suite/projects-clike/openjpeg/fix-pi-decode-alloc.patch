+/* Decode-side packet-iterator include vector; without a cap, pathological SIZ /
+ * COD combinations can force multi-gigabyte allocations while still passing
+ * header checks (e.g. extreme aspect ratios). */
+#ifndef OPJ_PI_DECODE_INCLUDE_CAP
+#define OPJ_PI_DECODE_INCLUDE_CAP (268435456U)
+#endif
+
 /** @defgroup PI PI - Implementation of a packet iterator */
 /*@{*/
 
@@ -992,17 +999,35 @@ static void opj_get_all_encoding_parameters(const opj_image_t *p_image,
             l_py0 = opj_uint_floordivpow2(l_ry0, l_pdy) << l_pdy;
             l_px1 = opj_uint_ceildivpow2(l_rx1, l_pdx) << l_pdx;
             py1 = opj_uint_ceildivpow2(l_ry1, l_pdy) << l_pdy;
-            l_pw = (l_rx0 == l_rx1) ? 0 : ((l_px1 - l_px0) >> l_pdx);
-            l_ph = (l_ry0 == l_ry1) ? 0 : ((py1 - l_py0) >> l_pdy);
+            /* Guard against unsigned wrap in (l_px1 - l_px0) / (py1 - l_py0) on
+             * malformed codestreams; otherwise l_pw*l_ph explodes and packet-
+             * iterator allocations try to calloc multi-gigabyte buffers. */
+            if (l_rx0 == l_rx1) {
+                l_pw = 0;
+            } else if (l_px1 < l_px0) {
+                l_pw = 0;
+            } else {
+                l_pw = (l_px1 - l_px0) >> l_pdx;
+            }
+            if (l_ry0 == l_ry1) {
+                l_ph = 0;
+            } else if (py1 < l_py0) {
+                l_ph = 0;
+            } else {
+                l_ph = (py1 - l_py0) >> l_pdy;
+            }
             if (lResolutionPtr) {
                 *lResolutionPtr++ = l_pw;
                 *lResolutionPtr++ = l_ph;
             }
-            l_product = l_pw * l_ph;
-
-            /* update precision*/
-            if (l_product > *p_max_prec) {
-                *p_max_prec = l_product;
+            if (l_pw != 0 && l_ph != 0) {
+                OPJ_UINT64 prod = (OPJ_UINT64)l_pw * (OPJ_UINT64)l_ph;
+                if (prod <= (OPJ_UINT64)UINT32_MAX) {
+                    l_product = (OPJ_UINT32)prod;
+                    if (l_product > *p_max_prec) {
+                        *p_max_prec = l_product;
+                    }
+                }
             }
 
         }
