+    {
+        OPJ_UINT64 step_c = (OPJ_UINT64)l_max_prec * (OPJ_UINT64)l_step_p;
+        OPJ_UINT64 step_r = step_c * (OPJ_UINT64)numcomps;
+        OPJ_UINT64 step_l = step_r * (OPJ_UINT64)l_max_res;
+        if (step_c > (OPJ_UINT64)UINT32_MAX ||
+                step_r > (OPJ_UINT64)UINT32_MAX ||
